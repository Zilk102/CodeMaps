{
  "name": "codemaps",
  "version": "1.0.0",
  "description": "Living Blueprint for Code",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:wait\"",
    "electron:wait": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json && cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" electron-builder"
  },
  "dependencies": {
    "@sigma/node-image": "^3.0.0",
    "@types/cytoscape": "^3.21.9",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "cytoscape": "^3.33.2",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-klay": "^3.1.4",
    "elkjs": "^0.11.1",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "klayjs": "^0.4.1",
    "piscina": "^5.1.4",
    "react": "^19.2.5",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.5",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-zoom-pan-pinch": "^4.0.3",
    "sigma": "^3.0.2",
    "simple-git": "^3.36.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.22.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.9",
    "wait-on": "^7.0.0"
  }
}
