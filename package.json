{
  "name": "codemaps",
  "productName": "CodeMaps",
  "version": "1.0.0",
  "author": "Zilk102",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zilk102/CodeMaps.git"
  },
  "license": "MIT",
  "description": "Living Blueprint for Code",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:wait\"",
    "electron:wait": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "clean:build": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/clean-build.ps1",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "package:portable": "cross-env NODE_OPTIONS=--max-old-space-size=8192 electron-builder --win portable --x64",
    "build": "npm run clean:build && npm run typecheck && npm run build:renderer && npm run build:electron && electron-builder",
    "build:portable": "npm run clean:build && npm run typecheck && npm run build:renderer && npm run build:electron && npm run package:portable",
    "mcp:smoke": "node scripts/mcp-smoke-test.mjs"
  },
  "build": {
    "productName": "CodeMaps",
    "publish": [
      {
        "provider": "github",
        "owner": "Zilk102",
        "repo": "CodeMaps"
      }
    ],
    "appId": "com.codemaps.app",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "CodeMaps-${version}-portable.${ext}"
    },
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.wasm"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "piscina": "^5.1.4",
    "simple-git": "^3.36.0",
    "typescript": "^5.0.0",
    "web-tree-sitter": "^0.26.8",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@sigma/node-image": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "elkjs": "^0.11.1",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "klayjs": "^0.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-zoom-pan-pinch": "^4.0.3",
    "sigma": "^3.0.2",
    "tree-sitter-wasms": "^0.1.13",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  }
}
